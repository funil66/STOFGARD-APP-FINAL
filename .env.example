# ============================================
# AUTONOMIA ILIMITADA - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env e configure
# Documentação: docs/ARQUITETURA.md
# ============================================

# --------------------------------------------
# APLICAÇÃO BÁSICA
# --------------------------------------------
APP_NAME="AUTONOMIA ILIMITADA"           # Nome exibido no sistema
APP_ENV=local                 # local | production | staging
APP_KEY=                      # Gere com: php artisan key:generate
APP_DEBUG=true                # false em produção
APP_URL=http://localhost:8000 # URL completa do sistema
APP_TIMEZONE=America/Sao_Paulo

# Credenciais do admin inicial (sem fallback hardcoded)
FILAMENT_ADMIN_EMAIL=
FILAMENT_ADMIN_PASSWORD=

# Domínios centrais (separados por vírgula)
CENTRAL_DOMAINS=localhost

# --------------------------------------------
# MONITORAMENTO — SENTRY
# --------------------------------------------
SENTRY_LARAVEL_DSN=           # Dashboard: https://sentry.io — obrigatório em produção
SENTRY_TRACES_SAMPLE_RATE=0.1 # 10% das requisições rastreadas (performance tracking)
SENTRY_PROFILES_SAMPLE_RATE=0 # 0 em dev, 0.1 em staging

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# --------------------------------------------
# JWT (API Auth)
# --------------------------------------------
JWT_SECRET=                 # Gere com: php artisan jwt:secret
JWT_TTL_MINUTES=120         # Manter igual ao SESSION_LIFETIME para evitar estado duplo inconsistente

# --------------------------------------------
# LOGS
# --------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug               # debug | info | warning | error (production: warning)

# --------------------------------------------
# BANCO DE DADOS
# --------------------------------------------
# PostgreSQL 16 (padrão — prodution-ready, multi-tenancy, JSONB)
DB_CONNECTION=pgsql
DB_HOST=pgsql            # hostname do container no Docker Compose
DB_PORT=5432
DB_DATABASE=stofgard
DB_USERNAME=stofgard
DB_PASSWORD=secret       # Alterar em produção!
FORWARD_DB_PORT=5432     # Porta exposta no host (apenas dev)

# MySQL (legado — manter comentado a menos que necessário)
# DB_CONNECTION=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=stofgard
# DB_USERNAME=stofgard
# DB_PASSWORD=secret

# SQLite (somente testes/dusk locais sem Docker)
# DB_CONNECTION=sqlite

# --------------------------------------------
# SESSÃO E CACHE
# --------------------------------------------
SESSION_DRIVER=file          # file | database | redis
SESSION_LIFETIME=120          # Minutos
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis        # sync | database | redis (use redis em produção!)

CACHE_STORE=redis             # file | database | redis (use redis em produção!)
# CACHE_PREFIX=

# --------------------------------------------
# REDIS (se usar)
# --------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --------------------------------------------
# EMAIL
# --------------------------------------------
MAIL_MAILER=log               # log | smtp | mailgun | ses
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="contato@stofgard.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# --------------------------------------------
# AWS S3 (Backup externo)
# --------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --------------------------------------------
# GOOGLE CALENDAR
# --------------------------------------------
# Obtenha em: https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/google/callback"
GOOGLE_CALENDAR_ID=primary    # ID do calendário ou 'primary'

# --------------------------------------------
# INTEGRAÇÃO PIX (EFI/Gerencianet)
# --------------------------------------------
# Obtenha em: https://gerencianet.com.br
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_SANDBOX=true              # false em produção
EFI_PIX_KEY=                  # Sua chave PIX cadastrada
EFI_CERTIFICATE_PATH=         # /path/to/certificado.pem

# --------------------------------------------
# CLIMA (OpenWeatherMap)
# --------------------------------------------
# Obtenha em: https://openweathermap.org/api
OPENWEATHER_API_KEY=
OPENWEATHER_DEFAULT_CITY=Ribeirão Preto
WEATHER_UNITS=metric          # metric | imperial
WEATHER_LANG=pt_br

# --------------------------------------------
# GERAÇÃO DE PDF (Browserless — container remoto)
# --------------------------------------------
# Modo: 'browserless' (produção) ou 'local' (dev sem Docker)
BROWSERSHOT_MODE=browserless

# URL do container Browserless (no Docker Compose, o hostname é 'browserless')
BROWSERLESS_URL=http://browserless:3000
BROWSERLESS_TOKEN=            # Definir token seguro em produção!
BROWSERLESS_PORT=3000         # Porta exposta no host (apenas dev)
BROWSERLESS_MAX_SESSIONS=5    # Max sessões concorrentes (aumentar em prod)

BROWSERSHOT_TIMEOUT=60        # Timeout em segundos para renderização de PDF

# Modo 'local' apenas (quando BROWSERSHOT_MODE=local)
# BROWSERSHOT_CHROME_PATH=/home/sail/.cache/puppeteer/chrome/linux-144.0.7559.96/chrome-linux64/chrome
# BROWSERSHOT_NODE_PATH=/usr/bin/node
# BROWSERSHOT_NPM_PATH=/usr/bin/npm

# --------------------------------------------
# BACKUP
# --------------------------------------------
BACKUP_DISK=google            # local | s3 | google
BACKUP_NOTIFICATION_MAIL=     # Email para notificações de backup
BACKUP_ARCHIVE_PASSWORD=      # Senha para encriptar backup (opcional)

# Google Drive (necessário se BACKUP_DISK=google)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REFRESH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
BACKUP_ARCHIVE_PASSWORD=      # Senha para encriptar backup (opcional)

# --------------------------------------------
# OUTROS
# --------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# OpenAI (opcional - para recursos de IA)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --------------------------------------------
# 💰 FASE 1 — BILLING ENGINE (Asaas)
# --------------------------------------------
# Conta Asaas do Super Admin para cobrar os tenants
# Crie conta em: https://asaas.com
# API Key: https://app.asaas.com/config#access_token

# Super Admin (cobra os tenants)
ASAAS_API_KEY=              # $aact_... (token do Super Admin no Asaas)
ASAAS_WEBHOOK_TOKEN=        # Token para validar webhooks — gere com: php artisan tinker → Str::random(40)
ASAAS_SANDBOX=true          # true = sandbox (testes), false = produção

# PayPal (opcional, cobrança em paralelo)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SANDBOX=true

# Tiers de preço (valor mensal em R$)
# Define os limites dos planos SaaS
COMMERCIAL_WHATSAPP=5511999999999
PLAN_START_PRICE=49
PLAN_START_OS_LIMIT=30
PLAN_FREE_PRICE=0
PLAN_FREE_OS_LIMIT=30
PLAN_PRO_PRICE=97
PLAN_PRO_OS_LIMIT=0         # 0 = ilimitado
PLAN_ELITE_PRICE=197
PLAN_ELITE_OS_LIMIT=0       # 0 = ilimitado

# Fluxo legado PIX (rotas web antigas). Mantenha false para usar o trilho canônico.
LEGACY_PIX_FLOW_ENABLED=false
LEGACY_PIX_WEBHOOK_ENABLED=false

# Trial (dias de período gratuito para novos tenants)
TRIAL_DAYS=14

# --------------------------------------------
# EVOLUTION API (WhatsApp)
# --------------------------------------------
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-api-key-global
EVOLUTION_INSTANCE=stofgard
